{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/ngflux",
  "lib": {
    "entryFile": "src/public-api.ts",
    "styleIncludePaths": [
      "./src/scss"
    ]
  },
  "assets": [
    { "input": "src/scss", "glob": "**/*.scss", "output": "scss" },
    { "input": "src", "glob": "**/*.scss", "output": "." }
  ]
}
